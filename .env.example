PORT=8787

# OpenAI kernel
K7_MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_AGENTS_MODEL=gpt-5.5

# Optional model providers
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.5
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
OLLAMA_API_KEY=

# KAIZEN7 Mastra kernel (lib/mastra-kernel.mjs) — provider-agnostic model selection.
# Set exactly one of these; getBestAvailableModel() picks the first that is set,
# in this priority order (ARK first, then DeepSeek/Qwen/Zai/Kimi, then the
# generic OPENAI_API_KEY/ANTHROPIC_API_KEY/GEMINI_API_KEY above).
# ARK_API_KEY routes through BytePlus ModelArk Coding Plan (also used by OpenClaw).
ARK_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
GEMINI_API_KEY=

# Shopify Admin API
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2025-10

# Meta / Instagram
META_PAGE_ID=
META_ACCESS_TOKEN=
IG_USER_ID=
META_GRAPH_VERSION=v23.0

# LinkedIn
LINKEDIN_AUTHOR_URN=
LINKEDIN_ACCESS_TOKEN=

# X
X_USER_ACCESS_TOKEN=
