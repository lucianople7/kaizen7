{
  "schema": "kaizen7.loop_policy.v1",
  "system": {
    "id": "kaizen7-loop-os",
    "name": "KAIZEN7 Action–Reaction Loop OS",
    "version": "1.0.0",
    "principle": "KAIZEN7 decides the next bounded step, agents execute, evidence decides and verified outcomes improve the ecosystem."
  },
  "roles": {
    "frontend": "work",
    "coordinator": "kaizen7",
    "technical_executor": "codex",
    "creative_executor": "flowmatik",
    "business_target": "the-focux",
    "authority": "human"
  },
  "flow": [
    "objective",
    "preflight",
    "task_contract",
    "execution",
    "verification",
    "outcome_receipt",
    "learning_gate",
    "next_action"
  ],
  "states": [
    "preflight",
    "ready",
    "executing",
    "verifying",
    "adjusting",
    "learning",
    "next_action",
    "completed",
    "approval_required",
    "blocked",
    "budget_exhausted"
  ],
  "human_gates": [
    "preference",
    "spending",
    "publishing",
    "credentials",
    "deletion",
    "deployment",
    "legal_or_high_stakes_authority",
    "irreversible_external_effect"
  ],
  "limits": {
    "max_iterations": 8,
    "token_budget": 1200,
    "preflight_budget": 300,
    "max_failures": 2
  },
  "learning": {
    "minimum_verified_uses": 3,
    "require_evidence": true,
    "require_fresh_receipt": true,
    "promote_failed_outcomes": false
  },
  "profiles": {
    "research": {
      "routes": ["research_primary_sources"],
      "patterns": ["investiga", "research", "actual", "tendencia", "modelo", "repo", "fuente"],
      "stages": ["question", "search", "filter", "hypothesis", "test", "verify", "learn"]
    },
    "commerce": {
      "routes": [],
      "patterns": ["ecommerce", "commerce", "shopify", "producto", "venta", "margen", "tienda"],
      "stages": ["signal", "demand", "economics", "risk", "experiment", "verify", "learn"]
    },
    "creative": {
      "routes": [],
      "patterns": ["video", "creativ", "subtitul", "template", "flowmatik", "contenido", "guion"],
      "stages": ["signal", "concept", "draft", "critique", "revise", "verify", "learn"]
    },
    "tool": {
      "routes": [],
      "patterns": ["herramienta", "tool", "api", "cli", "mcp", "adapter", "conector"],
      "stages": ["need", "shortlist", "isolate", "test", "compare", "verify", "learn"]
    },
    "memory": {
      "routes": ["reuse_receipt"],
      "patterns": ["memoria", "memory", "recall", "receipt", "recibo", "recordar"],
      "stages": ["retrieve", "deduplicate", "validate", "reuse", "verify", "learn"]
    },
    "technical": {
      "routes": ["codex_execute"],
      "patterns": ["implement", "codigo", "code", "parser", "prueba", "test", "kernel", "sistema"],
      "stages": ["inspect", "hypothesis", "test", "change", "verify", "adjust", "learn"]
    },
    "general": {
      "routes": [],
      "patterns": [],
      "stages": ["observe", "decide", "execute", "verify", "adjust", "learn"]
    }
  },
  "routing": {
    "codex_execute": "codex",
    "research_primary_sources": "work",
    "reuse_receipt": "work",
    "technical_patterns": [
      "implement",
      "codigo",
      "code",
      "cli",
      "comando",
      "api",
      "parser",
      "prueba",
      "test",
      "kernel",
      "sistema",
      "system",
      "repositorio"
    ],
    "creative_patterns": [
      "video",
      "creativ",
      "creative",
      "subtitul",
      "subtitle",
      "template",
      "flowmatik"
    ]
  }
}
