{
  "schema": "kaizen7.project_connectivity_map.v1",
  "updated": "2026-07-08",
  "principle": "KAIZEN7 vive como kernel en este repo. Los proyectos viven en repos separados y comparten rutas, evidencia y memoria mediante contratos pequenos.",
  "repository_policy": {
    "kaizen7_repo_owns": [
      "metaskills",
      "routing",
      "memory_contracts",
      "verification_receipts",
      "project_handoff_contracts",
      "agent_rules"
    ],
    "kaizen7_repo_does_not_own": [
      "public_brand_sites",
      "video_factory_implementation",
      "commerce_surfaces",
      "project_ip",
      "channel_content",
      "rendered_assets"
    ],
    "legacy_project_material": "Treat project folders still present in the KAIZEN7 working tree as extraction backlog unless the mission explicitly changes KAIZEN7 contracts, routing, receipts or memory."
  },
  "master_direction": {
    "obsidian": "Obsidian/Flowmatik/Arquitectura/Ecosistema Maestro KAIZEN7 Flowmatik THE FOCUX.md",
    "docs": "docs/ECOSYSTEM_MASTER_DIRECTION.md",
    "thesis": "contenido -> confianza -> founding list -> dossiers -> seleccion curada -> producto propio"
  },
  "projects": [
    {
      "id": "kaizen7",
      "name": "KAIZEN7",
      "repository": "kaizen7",
      "role": "Metaskill, memory, routing and verification kernel.",
      "improve_individually_by": [
        "mantener el kernel pequeno",
        "registrar capacidades reutilizables",
        "verificar resultados con evidence gates",
        "reducir contexto antes de actuar"
      ],
      "exports": ["skill_registry", "project_routes", "verification_receipts", "memory_writebacks", "handoff_contracts"],
      "imports": ["project_objectives", "evidence_packets", "tool_manifests"],
      "do_not_own": ["public_brand", "commerce_offer", "raw_creator_identity"]
    },
    {
      "id": "flowmatik",
      "name": "Flowmatik",
      "repository": "external_repo",
      "role": "Creative and operating pipeline for content, video, assets and distribution packets.",
      "improve_individually_by": [
        "crear fabricas repetibles de contenido",
        "mantener plantillas audiovisuales reutilizables",
        "separar guion, storyboard, audio, render y publicacion",
        "guardar SOPs despues de cada flujo que funcione"
      ],
      "exports": ["content_packs", "render_manifests", "storyboards", "video_assets", "distribution_packets"],
      "imports": ["brand_rules", "dossiers", "persona_voice", "claims_guard"],
      "do_not_own": ["regulatory_verdict", "product_checkout", "kernel_decisions"]
    },
    {
      "id": "the_focux",
      "name": "THE FOCUX",
      "repository": "external_repo",
      "role": "Premium performance brand, public platform, dossier engine and future selection commerce.",
      "improve_individually_by": [
        "priorizar confianza antes que venta",
        "publicar dossiers verificables",
        "mantener compliance visible",
        "crear seleccion pequena y curada"
      ],
      "exports": ["brand_rules", "dossiers", "evidence_index", "allowed_claims", "founding_list_signals"],
      "imports": ["research_sources", "content_assets", "kaizen7_verification", "supplier_candidates"],
      "do_not_own": ["agent_kernel", "generic_tool_registry", "raw_video_runtime"]
    },
    {
      "id": "mr_kaizen",
      "name": "Kaizen",
      "repository": "external_repo_or_channel",
      "role": "Persona, host and trust-building content interface.",
      "improve_individually_by": [
        "mantener voz consistente",
        "ensenar antes de vender",
        "hablar desde experiencias del mundo real",
        "convertir ideas complejas en accion diaria"
      ],
      "exports": ["scripts", "hooks", "voice_rules", "community_questions"],
      "imports": ["dossiers", "brand_rules", "flowmatik_templates", "claims_guard"],
      "do_not_own": ["medical_advice", "hard_claims", "checkout"]
    },
    {
      "id": "thefocuxos",
      "name": "THE FOCUX OS / NEUROCITY",
      "repository": "external_project_repo",
      "role": "Educational IP and concept system outside KAIZEN7 core.",
      "improve_individually_by": [
        "hacer conceptos memorables",
        "usar metaforas amigables y no futuristas en exceso",
        "convertir ciencia en rutas de aprendizaje",
        "alimentar academia, retos y contenido"
      ],
      "exports": ["learning_tracks", "concepts", "challenge_structures", "academy_modules"],
      "imports": ["science_dossiers", "mr_kaizen_voice", "brand_guardrails"],
      "do_not_own": ["product_claims", "legal_compliance", "tool_runtime"]
    }
  ],
  "shared_contracts": [
    {
      "id": "source_to_signal",
      "from": "external_research",
      "to": "kaizen7",
      "payload": ["source", "summary", "claims", "risks", "recommended_action"]
    },
    {
      "id": "dossier_to_content",
      "from": "the_focux",
      "to": "flowmatik",
      "payload": ["dossier_id", "safe_angle", "blocked_claims", "story_hooks", "visual_direction"]
    },
    {
      "id": "content_to_persona",
      "from": "flowmatik",
      "to": "mr_kaizen",
      "payload": ["script", "scene_context", "cta", "voice_constraints", "claims_guard"]
    },
    {
      "id": "artifact_to_memory",
      "from": "any_project",
      "to": "kaizen7",
      "payload": ["artifact_path", "decision", "evidence", "result", "next_action"]
    },
    {
      "id": "capability_to_provider",
      "from": "kaizen7",
      "to": "local_or_external_tool",
      "payload": ["capability_id", "provider", "manifest", "cost", "offline", "verification"]
    },
    {
      "id": "product_to_claims_guard",
      "from": "the_focux",
      "to": "compliance_gate",
      "payload": ["product_or_ingredient", "source", "claim", "evidence_level", "allowed_language", "blocked_language"]
    }
  ],
  "next_actions": [
    "estabilizar entrypoints documentados del kernel KAIZEN7",
    "crear checklist de extraccion para Flowmatik, THE FOCUX y Mr. Kaizen",
