{
  "schema": "kaizen7.capabilities.v1",
  "version": 1,
  "default_operator": "codex",
  "capabilities": [
    {
      "id": "kernel.capability_registry",
      "domain": "kernel",
      "purpose": "Load, validate and list KAIZEN7 capability contracts.",
      "status": "active",
      "inputs": ["objective"],
      "outputs": ["capability_list", "validation_errors"],
      "requires": [],
      "tools": ["local"],
      "approval": [],
      "verification": ["registry_valid", "tests_passed"],
      "writeback": "kernel_learning",
      "keywords": ["capability", "registry", "kernel", "contracts"]
    },
    {
      "id": "kernel.capability_resolver",
      "domain": "kernel",
      "purpose": "Resolve an objective to the smallest useful capability or chain.",
      "status": "active",
      "inputs": ["objective", "constraints"],
      "outputs": ["capability_plan"],
      "requires": ["kernel.capability_registry"],
      "tools": ["local"],
      "approval": [],
      "verification": ["plan_has_capability", "risks_reported"],
      "writeback": "kernel_learning",
      "keywords": ["resolve", "route", "objective", "plan"]
    },
    {
      "id": "kernel.capability_forge",
      "domain": "kernel",
      "purpose": "Forge new capability drafts with portable specs, evidence gates and safe registration guidance.",
      "status": "active",
      "inputs": ["objective", "domain", "id"],
      "outputs": ["capability_draft", "capability_spec", "validation_errors"],
      "requires": ["kernel.capability_registry"],
      "tools": ["codex", "local"],
      "approval": ["registry_write"],
      "verification": ["draft_valid", "spec_present", "review_required"],
      "writeback": "kernel_learning",
      "keywords": ["forge", "forjar", "skill", "capability", "habilidad", "crear capacidad"]
    },
    {
      "id": "code.change",
      "domain": "code",
      "purpose": "Make a scoped code change with tests.",
      "status": "active",
      "inputs": ["objective", "allowed_files", "context"],
      "outputs": ["diff", "tests", "risks"],
      "requires": ["kernel.capability_resolver"],
      "tools": ["codex"],
      "approval": ["delete", "credential_write", "install_dependencies"],
      "verification": ["diff_present", "tests_passed", "risks_reported"],
      "writeback": "code_learning",
      "keywords": ["code", "implement", "fix", "tests", "refactor", "codex"]
    },
    {
      "id": "code.review",
      "domain": "code",
      "purpose": "Review code changes for bugs, risks and missing tests.",
      "status": "active",
      "inputs": ["diff", "objective"],
      "outputs": ["findings", "risk_summary"],
      "requires": [],
      "tools": ["codex"],
      "approval": [],
      "verification": ["findings_grounded", "risks_reported"],
      "writeback": "review_learning",
      "keywords": ["review", "bugs", "risk", "tests"]
    },
    {
      "id": "content.reel.script",
      "domain": "content",
      "purpose": "Create a short-form script that can be verified before production.",
      "status": "active",
      "inputs": ["objective", "brand", "audience", "constraints"],
      "outputs": ["script", "shot_list", "claims"],
      "requires": ["memory.brand", "judge.claims"],
      "tools": ["codex"],
      "approval": ["medical_claims", "publish"],
      "verification": ["script_has_hook", "claims_checked", "risks_reported"],
      "writeback": "content_learning",
      "keywords": ["reel", "script", "short", "mr kaizen", "content", "guion"]
    },
    {
      "id": "content.storyboard",
      "domain": "content",
      "purpose": "Convert a script into a compact shot list and storyboard plan.",
      "status": "active",
      "inputs": ["script", "visual_style", "duration"],
      "outputs": ["shot_list", "asset_brief"],
      "requires": ["content.reel.script"],
      "tools": ["codex"],
      "approval": [],
      "verification": ["shot_list_present", "asset_brief_present"],
      "writeback": "content_learning",
      "keywords": ["storyboard", "shots", "visual", "flowmatik"]
    },
    {
      "id": "video.render_plan",
      "domain": "video",
      "purpose": "Plan a renderable video package without executing publishing or paid tools.",
      "status": "active",
      "inputs": ["shot_list", "assets", "duration"],
      "outputs": ["render_plan", "asset_manifest"],
      "requires": ["content.storyboard"],
      "tools": ["codex", "local"],
      "approval": ["publish"],
      "verification": ["render_plan_present", "risks_reported"],
      "writeback": "video_learning",
      "keywords": ["video", "render", "flowmatik", "assets"]
    },
    {
      "id": "persona.voice",
      "domain": "content",
      "purpose": "Apply Mr. Kaizen voice, tone and narrative constraints to content.",
      "status": "active",
      "inputs": ["objective", "brand_memory"],
      "outputs": ["voice_rules", "tone_constraints"],
      "requires": ["memory.brand"],
      "tools": ["codex"],
      "approval": [],
      "verification": ["voice_rules_present"],
      "writeback": "content_learning",
      "keywords": ["mr kaizen", "voice", "persona", "tone"]
    },
    {
      "id": "claims.check",
      "domain": "commerce",
      "purpose": "Check product, supplement and wellness claims before content or commerce use.",
      "status": "active",
      "inputs": ["claims", "market", "evidence"],
      "outputs": ["allowed_claims", "blocked_claims", "risk_notes"],
      "requires": [],
      "tools": ["codex"],
      "approval": ["medical_claims"],
      "verification": ["blocked_claims_reported", "sources_reported"],
      "writeback": "claims_learning",
      "keywords": ["claims", "the focux", "supplement", "medical", "regulation"]
    },
    {
      "id": "commerce.product_page",
      "domain": "commerce",
      "purpose": "Draft a product page from verified product and claims inputs.",
      "status": "active",
      "inputs": ["product_brief", "allowed_claims", "audience"],
      "outputs": ["product_page_draft", "claims_used"],
      "requires": ["claims.check"],
      "tools": ["codex"],
      "approval": ["publish", "commerce_write"],
      "verification": ["claims_checked", "risks_reported"],
      "writeback": "commerce_learning",
      "keywords": ["product page", "the focux", "commerce", "shopify"]
    },
    {
      "id": "research.pattern_intake",
      "domain": "research",
      "purpose": "Turn external repos, models or tools into sourceable KAIZEN7 adaptation decisions.",
      "status": "active",
      "inputs": ["source", "objective"],
      "outputs": ["patterns", "verdict", "risks"],
      "requires": [],
      "tools": ["github", "huggingface", "codex"],
      "approval": [],
      "verification": ["sources_reported", "risks_reported", "verdict_present"],
      "writeback": "architecture_decision",
      "keywords": ["research", "github", "huggingface", "repo", "pattern"]
    },
    {
      "id": "memory.writeback_draft",
      "domain": "memory",
      "purpose": "Draft reusable learning without writing secrets or raw transcripts.",
      "status": "active",
      "inputs": ["evidence", "decision", "risks"],
      "outputs": ["memory_draft"],
      "requires": [],
      "tools": ["local"],
      "approval": [],
      "verification": ["no_secrets", "decision_present"],
      "writeback": "memory_learning",
      "keywords": ["memory", "writeback", "obsidian", "learning"]
    },
    {
      "id": "agent.handoff_cycle",
      "domain": "agent",
      "purpose": "Coordinate work with another agent through handoff, receipt, verification and memory draft.",
      "status": "active",
      "inputs": ["objective", "consumer", "result_evidence"],
      "outputs": ["bridge", "cycle", "receipt", "repair_request"],
      "requires": ["kernel.capability_resolver"],
      "tools": ["codex", "local"],
      "approval": [],
      "verification": ["bridge_present", "cycle_verdict", "receipt_schema_valid"],
      "writeback": "agent_learning",
      "keywords": ["agent", "handoff", "delegate", "cycle", "bridge", "receipt"]
    },
    {
      "id": "project.context_intake",
      "domain": "project",
      "purpose": "Turn project identity, constraints and context into a compact capability-ready brief.",
      "status": "active",
      "inputs": ["project", "objective", "context"],
      "outputs": ["project_brief", "boundaries", "capability_hints"],
      "requires": ["memory.writeback_draft"],
      "tools": ["codex", "local"],
      "approval": [],
      "verification": ["context_summary_present", "boundaries_present", "risks_reported"],
      "writeback": "project_learning",
      "keywords": ["project", "context", "brief", "flowmatic", "focus", "mr kaizen"]
    },
    {
      "id": "app.integration_plan",
      "domain": "app",
      "purpose": "Plan safe interaction with an external application or connector before any external effect.",
      "status": "active",
      "inputs": ["app", "objective", "permissions"],
      "outputs": ["integration_plan", "approval_map", "evidence_contract"],
      "requires": ["kernel.capability_resolver"],
      "tools": ["codex", "connector"],
      "approval": ["external_write", "secrets", "publish"],
      "verification": ["approval_map_present", "evidence_contract_present", "no_unapproved_external_effect"],
      "writeback": "app_learning",
      "keywords": ["app", "application", "connector", "permisos", "aplicacion", "integration"]
    },
    {
      "id": "super.agent_companion",
      "domain": "super",
      "purpose": "Give any agent a compact companion loop: offer, bridge, packet, readiness, cycle and learning.",
      "status": "active",
      "inputs": ["objective", "agent", "context"],
      "outputs": ["working_brief", "cycle", "teaching_packet"],
      "requires": ["agent.handoff_cycle", "memory.writeback_draft"],
      "tools": ["codex", "local"],
      "approval": [],
      "verification": ["steps_reduced", "cycle_verdict", "learning_packet_present"],
      "writeback": "agent_learning",
      "keywords": ["super", "agent", "companion", "codex", "less steps", "orchestration"]
    },
    {
      "id": "super.project_navigator",
      "domain": "super",
      "purpose": "Turn any project into a capability-ready operating map without loading a large project brain.",
      "status": "active",
      "inputs": ["project", "objective", "context"],
      "outputs": ["project_map", "capability_route", "boundary"],
      "requires": ["project.context_intake", "kernel.capability_resolver"],
      "tools": ["codex", "local"],
      "approval": [],
      "verification": ["project_map_present", "capability_route_present", "risks_reported"],
      "writeback": "project_learning",
      "keywords": ["super", "project", "navigator", "flowmatic", "focus", "mr kaizen"]
    },
    {
      "id": "super.content_engine",
      "domain": "super",
      "purpose": "Create verified content packages from idea to script, storyboard and learning without publishing.",
      "status": "active",
      "inputs": ["objective", "brand", "audience"],
      "outputs": ["script", "storyboard", "render_plan", "content_learning"],
      "requires": ["content.reel.script", "content.storyboard", "video.render_plan", "claims.check"],
      "tools": ["codex", "local"],
      "approval": ["publish", "medical_claims"],
      "verification": ["claims_checked", "shot_list_present", "render_plan_present", "steps_reduced"],
      "writeback": "content_learning",
      "keywords": ["super", "content", "mr kaizen", "flowmatic", "reel", "video"]
    },
    {
      "id": "super.safe_app_operator",
      "domain": "super",
      "purpose": "Plan and gate app or connector work with approvals before any external effect.",
      "status": "active",
      "inputs": ["app", "objective", "permissions"],
      "outputs": ["integration_plan", "approval_map", "evidence_contract", "safe_next_action"],
      "requires": ["app.integration_plan", "agent.handoff_cycle"],
      "tools": ["codex", "connector"],
      "approval": ["external_write", "secrets", "publish"],
      "verification": ["approval_map_present", "no_unapproved_external_effect", "evidence_contract_present"],
      "writeback": "app_learning",
      "keywords": ["super", "app", "connector", "safe", "approval", "operator"]
    },
    {
      "id": "super.capability_builder",
      "domain": "super",
      "purpose": "Forge, review and teach new repeatable capabilities without bloating the kernel.",
      "status": "active",
      "inputs": ["need", "domain", "evidence"],
      "outputs": ["capability_draft", "capability_spec", "learning_loop"],
      "requires": ["kernel.capability_forge", "memory.writeback_draft"],
      "tools": ["codex", "local"],
      "approval": ["registry_write"],
      "verification": ["draft_valid", "spec_present", "review_required", "learning_packet_present"],
      "writeback": "kernel_learning",
      "keywords": ["super", "capability", "forge", "builder", "skills", "habilidades"]
    },
    {
      "id": "super.evidence_guardian",
      "domain": "super",
      "purpose": "Guard claims, receipts and learning so agents only advance with evidence.",
      "status": "active",
      "inputs": ["cycle", "claims", "evidence"],
      "outputs": ["verification", "receipt", "blockers", "teaching_packet"],
      "requires": ["agent.handoff_cycle", "claims.check", "memory.writeback_draft"],
      "tools": ["codex", "local"],
      "approval": ["medical_claims"],
      "verification": ["receipt_schema_valid", "blocked_claims_reported", "evidence_present"],
      "writeback": "quality_learning",
      "keywords": ["super", "evidence", "guardian", "claims", "receipt", "learning"]
    },
    {
      "id": "super.next_best_action",
      "domain": "super",
      "purpose": "Choose the next best action for an agent from state, objective, missing inputs, evidence and approvals.",
      "status": "active",
      "inputs": ["objective", "state", "missing_inputs", "approval_state", "evidence"],
      "outputs": ["recommended_capability", "reason", "inputs_needed", "evidence_required", "next_action"],
      "requires": ["kernel.capability_resolver", "super.evidence_guardian", "kernel.capability_forge"],
      "tools": ["codex", "local"],
      "approval": [],
      "verification": ["recommended_capability_present", "stop_condition_present", "risks_reported", "steps_reduced"],
      "writeback": "agent_learning",
      "keywords": ["super", "next", "best", "action", "siguiente", "mejor", "accion", "decision", "brujula"]
    },
    {
      "id": "super.agent_workbench",
      "domain": "super",
      "purpose": "Give an agent one compact workbench with context capsule, next best action, capability spec, execution recipe, evidence gates and learning rule.",
      "status": "active",
      "inputs": ["objective", "project", "context", "state"],
      "outputs": ["context_capsule", "next_best_action", "capability_spec", "execution_recipe", "evidence_required", "learning_rule"],
      "requires": ["super.next_best_action", "agent.handoff_cycle", "memory.writeback_draft"],
      "tools": ["codex", "local"],
      "approval": [],
      "verification": ["context_capsule_present", "next_action_present", "execution_recipe_present", "evidence_required", "steps_reduced"],
      "writeback": "agent_learning",
      "keywords": ["super", "agent", "workbench", "mesa", "trabajo", "receta", "context", "capsule", "recipe"]
    },
    {
      "id": "world.mcp_tool_plan",
      "domain": "world",
      "purpose": "Plan an MCP tool call with inputs, expected output, evidence and approval gates before execution.",
      "status": "active",
      "inputs": ["server", "tool", "objective", "params"],
      "outputs": ["mcp_call_plan", "evidence_contract", "risk_notes"],
      "requires": ["app.integration_plan"],
      "tools": ["mcp", "codex"],
      "approval": ["external_write", "secrets"],
      "verification": ["tool_selected", "params_mapped", "evidence_contract_present", "no_unapproved_external_effect"],
      "writeback": "world_learning",
      "keywords": ["world", "mcp", "tool", "server", "external", "apps"]
    },
    {
      "id": "world.app_connector_plan",
      "domain": "world",
      "purpose": "Plan connector interaction with account, permission and result evidence boundaries.",
      "status": "active",
      "inputs": ["connector", "account", "objective", "permissions"],
      "outputs": ["connector_plan", "approval_map", "receipt_expectation"],
      "requires": ["app.integration_plan", "agent.handoff_cycle"],
      "tools": ["connector", "codex"],
      "approval": ["external_write", "publish", "secrets"],
      "verification": ["approval_map_present", "receipt_schema_valid", "no_unapproved_external_effect"],
      "writeback": "world_learning",
      "keywords": ["world", "connector", "conector", "conectores", "gmail", "drive", "notion", "github", "shopify", "apps"]
    },
    {
      "id": "world.clip_intake",
      "domain": "world",
      "purpose": "Turn clips, snippets or pasted artifacts into structured evidence-ready context.",
      "status": "active",
      "inputs": ["clip", "source", "objective"],
      "outputs": ["clip_summary", "claims", "artifact_refs", "risks"],
      "requires": ["memory.writeback_draft"],
      "tools": ["codex", "local"],
      "approval": [],
      "verification": ["artifact_refs_present", "claims_extracted", "risks_reported"],
      "writeback": "world_learning",
      "keywords": ["world", "clip", "clips", "snippet", "artifact", "paste", "input"]
    },
    {
      "id": "world.artifact_export_plan",
      "domain": "world",
      "purpose": "Plan file, document, image or video artifact handoff with manifest and verification requirements.",
      "status": "active",
      "inputs": ["artifact", "format", "destination"],
      "outputs": ["artifact_manifest", "handoff_plan", "verification_steps"],
      "requires": ["agent.handoff_cycle"],
      "tools": ["codex", "local"],
      "approval": ["external_write", "publish"],
      "verification": ["artifact_manifest_present", "verification_steps_present", "approval_state_reported"],
      "writeback": "world_learning",
      "keywords": ["world", "artifact", "export", "file", "document", "image", "video"]
    }
  ]
}
